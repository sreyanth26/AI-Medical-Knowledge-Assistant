# AI Medical Knowledge Assistant — Environment Variables
# Copy this to .env and fill in your values

# Ollama settings (local LLM)
LLM_MODEL=llama3
OLLAMA_HOST=http://localhost:11434

# FAISS index storage
VECTOR_INDEX_PATH=models/faiss_index

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
API_BASE_URL=http://localhost:8000
